    await m.answer_photo(photo=LOGO_URL, caption=f"👋 Salom {m.from_user.first_name}!\n\nRocket AI Terminalga xush kelibsiz!", reply_markup=get_main_kb())

@dp.callback_query()
async def callbacks(cb: types.CallbackQuery):
    if cb.data == "choose_pair":
        await cb.message.edit_caption(caption="📊 *Analiz uchun tanlang (M15+H1 filtri yoniq):*", reply_markup=get_pairs_kb())
    elif cb.data.startswith("analyze_"):
        pair = cb.data.split("_")[1]
        res = await get_analysis(pair)
        await cb.message.answer(res)
    elif cb.data == "premium":
        text = ("💎 *PREMIUM IMKONIYATLAR:*\n\n"
                "• 24/7 Avtomat AI tahlillar\n"
                "• Aniq TP va SL darajalari\n"
                "• VIP signallar kanali\n\n"
                "Murojaat: @intixo0707")
        await cb.message.edit_caption(caption=text, reply_markup=InlineKeyboardMarkup(inline_keyboard=[[InlineKeyboardButton(text="⬅️ Orqaga", callback_data="back")]]))
    elif cb.data == "back":
        await cb.message.edit_caption(caption="🚀 *ROCKET AI TERMINAL*", reply_markup=get_main_kb())
    elif cb.data == "stats":
        await cb.answer("AI aniqlik darajasi: 91% ✅", show_alert=True)
    await cb.answer()

