    except Exception as e:
        logging.error(f"AI Error: {e}")
        return "AI tahlili hozircha band, lekin texnik signal kuchli! 🚀"

# ==================== 3. MULTI-FILTER TAHLIL (M15 + H1) ====================
async def get_analysis(symbol_key):
    try:
        # TradingView blokirovka qilmasligi uchun biroz kutish
        await asyncio.sleep(1)
        data = SYMBOLS[symbol_key]
        
        # M15 va H1 tahlillari (Thread yordamida tezlashtirildi)
        def fetch_ta():
            h_m15 = TA_Handler(symbol=data["symbol"], screener=data["screener"], 
                               exchange=data["exchange"], interval=Interval.INTERVAL_15_MINUTES)
            h_h1 = TA_Handler(symbol=data["symbol"], screener=data["screener"], 
                              exchange=data["exchange"], interval=Interval.INTERVAL_1_HOUR)
            return h_m15.get_analysis(), h_h1.get_analysis()

        analysis_m15, analysis_h1 = await asyncio.to_thread(fetch_ta)

        rec_m15 = analysis_m15.summary['RECOMMENDATION']
        rec_h1 = analysis_h1.summary['RECOMMENDATION']
        
        price = analysis_m15.indicators['close']
        rsi = round(analysis_m15.indicators['RSI'], 1)

        # FILTR: Trendlar mos kelsa
        if ("BUY" in rec_m15 and "BUY" in rec_h1) or ("SELL" in rec_m15 and "SELL" in rec_h1):
            ai_comment = await get_ai_opinion(symbol_key, price, rec_m15, rsi)
            
            emoji = "🚀" if "BUY" in rec_m15 else "📉"
            return (f"{emoji} *SUPER SIGNAL: {symbol_key}*\n\n"
                    f"💎 Narx: `{price}`\n"
                    f"📢 Signal: *{rec_m15}* (Tasdiqlandi)\n"
                    f"📈 RSI: `{rsi}`\n\n"
                    f"🤖 **AI TAHLILI:**\n_{ai_comment.strip()}_")
        
        return (f"⏳ *{symbol_key} KUTISH REJIMIDA*\n\n"
                f"M15: `{rec_m15}`\nH1: `{rec_h1}`\n"
                f"Narx: `{price}`\n\n_Trendlar mos kelishini kuting..._")

    except Exception as e:
        logging.error(f"TA Error {symbol_key}: {e}")
        return f"⚠️ {symbol_key} tahlilida texnik xato."

# ==================== 4. SERVISLAR ====================
async def keep_alive():
    async with aiohttp.ClientSession() as session:
        while True:
            try:
                async with session.get(RENDER_URL) as response:
                    logging.info(f"Ping: {response.status}")
            except: pass
            await asyncio.sleep(600)

async def auto_scanner():
    while True:
        for key in SYMBOLS:
            try:
                report = await get_analysis(key)
                if "SUPER SIGNAL" in report:
                    now = datetime.now().strftime("%H:%M")
                    await bot.send_message(ADMIN_ID, f"🔔 *MUHIM SIGNAL* [{now}]\n\n{report}")
                await asyncio.sleep(5)
            except: continue
        await asyncio.sleep(900)

