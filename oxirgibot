async def get_ai_opinion(symbol, price, signal, rsi):
    try:
        # Promptni yanada aniqroq qildik
        prompt = (f"Sen professional moliya tahlilchisisan. {symbol} juftligi hozir {price} narxda. "
                  f"Texnik ko'rsatkichlar '{signal}' deyapti, RSI esa {rsi}. "
